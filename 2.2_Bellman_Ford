#Core theory: relaxation의 반복, 정점의 개수가 V개일때, 최단 경로는 아무리 길어도 V-1 개의 간선을 지난다.
#초기화 : 시작 노드 거리는 0, 나머지는 무한대
# 반복탐색 (V-1)회: 모든 간선을 하나씩 꺼내어 확인, dist [v] > dist[u] + cost(u,v) 라면 dist[v]를 업데이트

#음수 사이클 확인(1회 더) : 한번 더 모든 간선을 확인했을 때 거리가 또 줄어든다면? 그건 돌때마다 비용이 줄어드는 음수 사이클이 있다는 뜻.
#모든 간선 방문하므로 다익스트라보다 느림
#음수 사이클 감지,V-1 번 돌았는데 V번째 또 거리가 줄어들면 음수 사이클 감지됨

# 음수 가중치에 +a 해서 보정? 불가능 가장 짧은 패스가 유리하게 됨.  -> 포텐션을 계산하는 Johnson's algorithm은 가능. 존슨 알고리즘하기위해 벨만-포트 어차피 실행해야됨


def bellman_ford(graph, start, v_count):
    # 1. 거리 테이블 초기화
    dist = [float('inf')] * (v_count + 1)
    dist[start] = 0

    # 2. V-1번 반복하며 모든 간선 확인
    for i in range(v_count):
        for u, v, cost in graph:
            if dist[u] != float('inf') and dist[v] > dist[u] + cost:
                dist[v] = dist[u] + cost
                # 3. V번째 반복에서도 값이 바뀌면 음수 사이클 존재
                if i == v_count - 1:
                    return "음수 사이클 발생!"
                    
    return dist

# (출발노드, 도착노드, 가중치)
edges = [
    (1, 2, 3), (1, 3, 5), (2, 3, 2), (3, 2, -7), (2, 4, 1)
]

# 1번 노드에서 시작, 전체 노드 개수 4개
print(bellman_ford(edges, 1, 4))
